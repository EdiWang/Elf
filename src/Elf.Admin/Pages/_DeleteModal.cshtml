<fluent-dialog id="deleteModal" type="modal" aria-labelledby="deleteModalLabel">
    <fluent-dialog-body>
        <span slot="title" id="deleteModalLabel">Confirm Delete</span>
        <p>Are you sure you want to delete this link?</p>
        <div class="inline-alert warning">
            <strong>Token:</strong> <span id="deleteTokenPreview"></span><br>
            <strong>URL:</strong> <span id="deleteUrlPreview"></span>
        </div>
        <p class="danger-text">This action cannot be undone.</p>
        <fluent-button slot="action" appearance="secondary" type="button" data-dialog-close>Cancel</fluent-button>
        <fluent-button slot="action" appearance="primary" type="button" id="confirmDeleteBtn">Delete</fluent-button>
    </fluent-dialog-body>
</fluent-dialog>
