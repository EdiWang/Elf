@page "/RecentRequests"
@{
    ViewData["Title"] = "Recent Requests";
}

<div class="report-sections">
    <details class="elf-disclosure" id="requestsTableDisclosure" open>
        <summary>Recent Requests</summary>
        <div class="disclosure-body">
            @if (LinkId != null)
            {
                <p class="muted-text">Showing requests for link ID @LinkId.</p>
            }

            <section class="recent-requests-container">
                <div class="fluent-table-surface">
                    <div class="fluent-table-scroll">
                        <table class="fluent-data-table" id="recentRequestsTable">
                            <thead>
                                <tr>
                                    <th scope="col">Token</th>
                                    <th scope="col">Note</th>
                                    <th scope="col">User Agent</th>
                                    <th scope="col">IP Address</th>
                                    <th scope="col">Location</th>
                                    <th scope="col">ASN</th>
                                    <th scope="col">Organization</th>
                                    <th scope="col">Request Time</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>
    </details>
</div>

@section scripts {
    <script>
        window.reportPageData = {
            linkId: @(LinkId?.ToString() ?? "null")
        };
    </script>
    <script src="~/js/recentRequests.mjs" type="module" asp-append-version="true"></script>
}

@functions {
    [BindProperty(SupportsGet = true)]
    public int? LinkId { get; set; }
}