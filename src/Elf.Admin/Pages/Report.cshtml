@page "/Report"
@{
    ViewData["Title"] = "Report";
}

<div class="report-sections" id="reportSections">
    <details class="elf-disclosure" id="chartsDisclosure" open>
        <summary>Charts</summary>
        <div class="disclosure-body">
                <section class="date-range-selector">
                    <form id="dateRangeForm">
                        <div class="date-command-bar">
                            <div class="form-field">
                                <label for="startDate">Start Date</label>
                                <input type="date" class="elf-input" id="startDate" name="startDate" required>
                                <div class="invalid-feedback" id="startDateError"></div>
                            </div>
                            <div class="form-field">
                                <label for="endDate">End Date</label>
                                <input type="date" class="elf-input" id="endDate" name="endDate" required>
                                <div class="invalid-feedback" id="endDateError"></div>
                            </div>
                            <div class="form-field command-align-end">
                                <fluent-button appearance="primary" type="button" id="refreshChartBtn">
                                    <fluent-progress-ring class="inline-progress d-none" id="refreshSpinner" aria-hidden="true"></fluent-progress-ring>
                                    <span class="elf-icon" aria-hidden="true">↻</span>
                                    Refresh Chart
                                </fluent-button>
                            </div>
                        </div>
                    </form>
                </section>
                <section class="chart-container">
                    <div class="chart-grid">
                        <fluent-card class="chart-card">
                                    <h2>Requests</h2>
                                    <div class="requests-line-chart-container">
                                        <canvas id="requestsLineChart" width="400" height="300"></canvas>
                                    </div>
                        </fluent-card>

                        <fluent-card class="chart-card">
                                    <h2>Client Types</h2>
                                    <div class="client-types-line-chart-container">
                                        <canvas id="clientTypesPieChart" width="400" height="300"></canvas>
                                    </div>
                        </fluent-card>

                        @if (LinkId == null)
                        {
                            <fluent-card class="chart-card">
                                        <h2>Most Requested Links</h2>
                                        <div class="most-requested-links-doughnut-chart-container">
                                            <canvas id="mostRequestedLinksDoughnutChart" width="400" height="300"></canvas>
                                        </div>
                            </fluent-card>
                        }
                    </div>
                </section>
        </div>
    </details>

    <details class="elf-disclosure" id="requestsTableDisclosure">
        <summary>Recent Requests</summary>
        <div class="disclosure-body">
                <section class="recent-requests-container">
                    <div class="table-scroll">
                        <table class="elf-table" id="recentRequestsTable">
                            <thead>
                                <tr>
                                    <th scope="col">Token</th>
                                    <th scope="col">Note</th>
                                    <th scope="col">User Agent</th>
                                    <th scope="col">IP Address</th>
                                    <th scope="col">Location</th>
                                    <th scope="col">ASN</th>
                                    <th scope="col">Organization</th>
                                    <th scope="col">Request Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Recent requests will be populated here -->
                            </tbody>
                        </table>
                    </div>
                </section>
        </div>
    </details>
</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.5.0/chart.umd.min.js" integrity="sha512-Y51n9mtKTVBh3Jbx5pZSJNDDMyY+yGe77DGtBPzRlgsf/YLCh13kSZ3JmfHGzYFCmOndraf0sQgfM654b7dJ3w==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        // Make linkId available to JavaScript modules
        window.reportPageData = {
            linkId: @(LinkId?.ToString() ?? "null")
        };
    </script>
    <script src="~/js/report.mjs" type="module" asp-append-version="true"></script>
}

@functions {
    [BindProperty(SupportsGet = true)]
    public int? LinkId { get; set; }
}