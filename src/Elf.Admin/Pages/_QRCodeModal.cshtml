<dialog class="elf-dialog qr-dialog" id="qrCodeModal" aria-labelledby="qrCodeModalLabel">
    <div class="dialog-header">
        <h2 id="qrCodeModalLabel">QR Code</h2>
        <fluent-button appearance="subtle" type="button" data-dialog-close aria-label="Close">×</fluent-button>
    </div>
    <div class="dialog-body qr-dialog-body">
        <canvas id="qrCodeCanvas"></canvas>
        <code id="qrCodeUrl" class="break-text"></code>
    </div>
    <div class="dialog-footer">
        <fluent-button appearance="secondary" type="button" data-dialog-close>Close</fluent-button>
    </div>
</dialog>