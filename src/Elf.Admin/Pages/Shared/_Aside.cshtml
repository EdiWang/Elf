@{
    var currentPage = ViewContext.RouteData.Values["Page"]?.ToString();
}

<nav class="sidebar-main-menu-wrapper" aria-label="Admin navigation">
    <fluent-tree class="main-menu" size="medium" appearance="subtle" tabindex="0" aria-label="Admin menu">
        <fluent-tree-item empty size="medium" appearance="subtle" tabindex="-1" @(currentPage is "/Index" ? "selected" : null)>
            <a class="tree-link" asp-page="./Index">
                <i class="bi bi-link-45deg tree-link__icon" aria-hidden="true"></i>
                <span class="tree-link__label">Links</span>
            </a>
        </fluent-tree-item>
        <fluent-tree-item empty size="medium" appearance="subtle" tabindex="-1" @(currentPage is "/Tags" ? "selected" : null)>
            <a class="tree-link" asp-page="./Tags">
                <i class="bi bi-tags tree-link__icon" aria-hidden="true"></i>
                <span class="tree-link__label">Tags</span>
            </a>
        </fluent-tree-item>
        <fluent-tree-item expanded size="medium" appearance="subtle" tabindex="-1" @(currentPage is "/Report" ? "selected" : null)>
            <span class="tree-link">
                <i class="bi bi-bar-chart-line tree-link__icon" aria-hidden="true"></i>
                <span class="tree-link__label">Analytics</span>
            </span>
            <fluent-tree-item slot="item" empty size="medium" appearance="subtle" tabindex="-1" data-indent="1" @(currentPage is "/Report" ? "selected" : null)>
                <a class="tree-link" asp-page="./Report">
                    <i class="bi bi-clipboard-data tree-link__icon" aria-hidden="true"></i>
                    <span class="tree-link__label">Report</span>
                </a>
            </fluent-tree-item>
        </fluent-tree-item>
    </fluent-tree>
</nav>
