@using Edi.AspNetCore.Utils
@using Elf.Shared
@inject IConfiguration Configuration
@{
    var forwarderBaseUrl = Configuration["ForwarderBaseUrl"] ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en" data-forwarder-base-url="@forwarderBaseUrl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elf Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("head", required: false)
</head>
<body>
    <header class="app-header">
        <nav class="app-topbar">
            <a class="app-brand" asp-area="" asp-page="/Index">Elf Admin</a>

            <div class="app-links">
                <a href="@forwarderBaseUrl" target="_blank">
                    <span class="elf-icon" aria-hidden="true">↗</span>
                    Forwarder API
                </a>

                <a href="https://github.com/EdiWang/Elf" target="_blank">
                    <span class="elf-icon" aria-hidden="true">◎</span>
                    @VersionHelper.AppVersionBasic
                </a>
            </div>
        </nav>
    </header>
    <div class="app-layout">
        <aside class="aside-container">
            <partial name="_Aside" />
        </aside>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <partial name="_Toast" />

    <script src="~/js/main.mjs" type="module" asp-append-version="true"></script>

    @await RenderSectionAsync("scripts", required: false)
</body>
</html>