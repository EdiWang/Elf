@using Edi.AspNetCore.Utils
@using Elf.Shared
@inject IConfiguration Configuration
@{
    var forwarderBaseUrl = Configuration["ForwarderBaseUrl"] ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en" data-forwarder-base-url="@forwarderBaseUrl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elf Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("head", required: false)
</head>
<body>
    <header class="navbar">
        <div class="navbar-left">
            <a class="navbar-brand" asp-area="" asp-page="/Index">Elf Admin</a>
        </div>
        <div class="navbar-center"></div>
        <div class="navbar-right">
            <span class="navbar-time" id="navbarTime"></span>
            <a class="edi-btn" href="@forwarderBaseUrl" target="_blank">
                <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                Forwarder API
            </a>
            <a class="edi-btn" href="https://github.com/EdiWang/Elf" target="_blank">
                <i class="bi bi-github" aria-hidden="true"></i>
                @VersionHelper.AppVersionBasic
            </a>
        </div>
    </header>
    <div class="app-layout">
        <aside class="aside-container">
            <partial name="_Aside" />
        </aside>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <partial name="_Toast" />

    <script src="~/js/main.mjs" type="module" asp-append-version="true"></script>

    @await RenderSectionAsync("scripts", required: false)
</body>
</html>