@page
@{
    ViewData["Title"] = "Links";
}

<section class="command-bar">
    <div class="command-group">
        <fluent-text-input type="text" id="searchTerm" placeholder="Search links by note or token..."></fluent-text-input>
        <fluent-button appearance="subtle" type="button" id="searchBtn" title="Search">
            <span class="elf-icon" aria-hidden="true">⌕</span>
        </fluent-button>
        <fluent-button appearance="subtle" type="button" id="clearBtn" title="Clear search">
            <span class="elf-icon" aria-hidden="true">⌫</span>
        </fluent-button>
    </div>
    <div class="command-group tag-search-group">
        <span class="command-prefix" aria-hidden="true">#</span>
        <input type="text" class="elf-input" id="tagFilter" placeholder="Select tags to filter...">
        <fluent-button appearance="subtle" type="button" id="tagSearchBtn" title="Search tags">
            <span class="elf-icon" aria-hidden="true">⌕</span>
        </fluent-button>
        <fluent-button appearance="subtle" type="button" id="clearTagFilterBtn" title="Clear tag filter">
            <span class="elf-icon" aria-hidden="true">×</span>
        </fluent-button>
    </div>
    <div class="command-actions">
        <fluent-button appearance="subtle" id="refreshBtn" title="Refresh links">
            <span class="elf-icon" aria-hidden="true">↻</span>
        </fluent-button>
        <fluent-button appearance="primary" id="addLinkBtn">
            <span class="elf-icon" aria-hidden="true">+</span>
            New
        </fluent-button>
    </div>
</section>

<div id="loadingSpinner" class="loading-panel d-none">
    <fluent-progress-ring></fluent-progress-ring>
    <span class="sr-only">Loading...</span>
</div>

<div id="linksContainer">
    <div id="linksData"></div>
</div>

<div id="noDataMessage" class="empty-state d-none">
    <h2>No links found</h2>
    <p>Try adjusting your search criteria or add a new link.</p>
</div>

<nav aria-label="Links pagination" id="paginationContainer" class="pagination-shell">
    <div class="pagination-size">
        <label for="pageSize">Show</label>
        <fluent-select id="pageSize">
            <fluent-option value="10" selected>10</fluent-option>
            <fluent-option value="25">25</fluent-option>
            <fluent-option value="50">50</fluent-option>
            <fluent-option value="100">100</fluent-option>
        </fluent-select>
        <span id="recordsInfo" class="muted-text"></span>
    </div>
    <div class="pagination-actions" id="pagination"></div>
</nav>

<partial name="_DeleteModal" />
<partial name="_LinkEditModal" />
<partial name="_QRCodeModal" />

@section scripts {
    <script src="~/lib/qrious/qrious.min.js"></script>
    <script src="~/lib/tagify/tagify.js" asp-append-version="true"></script>
    <script type="module" src="~/js/index.mjs" asp-append-version="true"></script>
}

@section head{
    <link href="~/lib/tagify/tagify.css" rel="stylesheet" asp-append-version="true" />
}