@page "/Tags"
@{
    ViewData["Title"] = "Tags";
}

<section class="page-actions">
    <fluent-button appearance="primary" type="button" id="addTagBtn">
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        New Tag
    </fluent-button>
</section>

<fluent-card class="form-card" id="tagForm" style="display: none;">
    <h2 id="formTitle">Create Tag</h2>
    <form id="tagEditForm">
        <input type="hidden" id="tagId" />
        <div class="form-field short-field">
            <fluent-text-input type="text" id="tagName" name="name" maxlength="32" required>Tag Name *</fluent-text-input>
            <div class="invalid-feedback" id="tagNameError"></div>
            <div class="form-help">Maximum 32 characters</div>
        </div>
        <div class="button-row">
            <fluent-button appearance="primary" type="submit" id="saveTagBtn">
                <i class="bi bi-check-lg" aria-hidden="true"></i>
                Save
            </fluent-button>
            <fluent-button appearance="secondary" type="button" id="cancelTagBtn">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                Cancel
            </fluent-button>
        </div>
    </form>
</fluent-card>

<!-- Tags List -->
<div id="loadingSpinner" class="loading-panel">
    <fluent-progress-ring></fluent-progress-ring>
    <span class="sr-only">Loading...</span>
</div>

<div id="noTagsMessage" class="empty-state" style="display: none;">
    <span class="empty-state-icon" aria-hidden="true">#</span>
    <p class="mt-2">No tags found. Create your first tag to get started.</p>
</div>

<div id="tagsGridContainer" style="display: none;">
    <div id="tagsGrid" class="tag-grid">
    </div>
</div>

<dialog class="elf-dialog" id="deleteTagModal" aria-labelledby="deleteTagModalLabel">
    <div class="dialog-header">
        <h2 id="deleteTagModalLabel">Confirm Delete</h2>
        <fluent-button appearance="subtle" type="button" data-dialog-close aria-label="Close">×</fluent-button>
    </div>
    <div class="dialog-body">
        <p>Are you sure you want to delete the tag "<strong id="deleteTagName"></strong>"?</p>
        <p class="danger-text"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i> This action cannot be undone.</p>
    </div>
    <div class="dialog-footer">
        <fluent-button appearance="secondary" type="button" data-dialog-close>Cancel</fluent-button>
        <fluent-button appearance="primary" type="button" id="confirmDeleteBtn">
            <i class="bi bi-trash" aria-hidden="true"></i>
            Delete
        </fluent-button>
    </div>
</dialog>

@section scripts {
    <script type="module" src="~/js/tags.mjs" asp-append-version="true"></script>
}