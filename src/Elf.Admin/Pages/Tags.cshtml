@page "/Tags"
@{
    ViewData["Title"] = "Tags";
}

<section class="command-bar">
    <div class="command-actions">
        <fluent-button appearance="primary" type="button" id="addTagBtn">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            New
        </fluent-button>
        <fluent-button type="button" id="refreshTagBtn" title="Refresh tags">
            <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
        </fluent-button>
        <div class="toolbar-selection-actions" aria-label="Selected tag actions">
            <fluent-button type="button" id="editTagActionBtn" title="Edit tag" disabled>
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
            </fluent-button>
            <fluent-button type="button" id="deleteTagActionBtn" class="danger-action" title="Delete tag" disabled>
                <i class="bi bi-trash" aria-hidden="true"></i>
            </fluent-button>
        </div>
    </div>
</section>

<fluent-dialog id="tagEditModal" type="modal" aria-labelledby="tagEditModalLabel">
    <fluent-dialog-body>
        <span slot="title" id="tagEditModalLabel">Create Tag</span>
        <form id="tagEditForm">
            <input type="hidden" id="tagId" />
            <div class="form-field short-field">
                <fluent-text-input type="text" id="tagName" name="name" maxlength="32" required>Tag Name *</fluent-text-input>
                <div class="invalid-feedback" id="tagNameError"></div>
                <div class="form-help">Maximum 32 characters</div>
            </div>
        </form>
        <fluent-button slot="action" appearance="secondary" type="button" id="cancelTagBtn">
            Cancel
        </fluent-button>
        <fluent-button slot="action" appearance="primary" type="submit" form="tagEditForm" id="saveTagBtn">
            Save
        </fluent-button>
    </fluent-dialog-body>
</fluent-dialog>

<!-- Tags List -->
<div id="loadingSpinner" class="loading-panel d-none">
    <fluent-progress-ring></fluent-progress-ring>
    <span class="sr-only">Loading...</span>
</div>

<div id="noTagsMessage" class="empty-state d-none">
    <span class="empty-state-icon" aria-hidden="true">#</span>
    <p class="mt-2">No tags found. Create your first tag to get started.</p>
</div>

<div id="tagsGridContainer" class="tags-grid-shell d-none">
    <div id="tagsGrid" class="tag-grid" role="listbox" aria-label="Tags" aria-orientation="horizontal"></div>
</div>

<fluent-dialog id="deleteTagModal" type="modal" aria-labelledby="deleteTagModalLabel">
    <fluent-dialog-body>
        <span slot="title" id="deleteTagModalLabel">Confirm Delete</span>
        <p>Are you sure you want to delete the tag "<strong id="deleteTagName"></strong>"?</p>
        <p class="danger-text"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i> This action cannot be undone.</p>
        <fluent-button slot="action" appearance="secondary" type="button" data-dialog-close>Cancel</fluent-button>
        <fluent-button slot="action" appearance="primary" type="button" id="confirmDeleteBtn">
            <i class="bi bi-trash" aria-hidden="true"></i>
            Delete
        </fluent-button>
    </fluent-dialog-body>
</fluent-dialog>

@section scripts {
    <script type="module" src="~/js/tags.mjs" asp-append-version="true"></script>
}