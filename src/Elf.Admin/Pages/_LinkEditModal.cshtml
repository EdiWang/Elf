<dialog class="elf-dialog wide-dialog" id="linkEditModal" aria-labelledby="linkEditModalLabel">
    <div class="dialog-header">
        <h2 id="linkEditModalLabel">Create Link</h2>
        <fluent-button appearance="subtle" type="button" data-dialog-close aria-label="Close">×</fluent-button>
    </div>
    <div class="dialog-body">
        <form id="linkEditForm">
            <div class="form-grid two-one">
                <div class="form-field">
                    <fluent-text-input type="url" id="originUrl" name="originUrl" required maxlength="256" placeholder="https://example.com">Origin URL *</fluent-text-input>
                    <div class="invalid-feedback" id="originUrlError"></div>
                </div>
                <div class="form-field">
                    <fluent-text-input type="number" id="ttl" name="ttl" min="0" max="86400" value="0" placeholder="0">TTL (seconds)</fluent-text-input>
                    <div class="form-help">0 = no expiration, max 24 hours</div>
                    <div class="invalid-feedback" id="ttlError"></div>
                </div>
            </div>

            <div class="form-grid two-even">
                <div class="form-field">
                    <fluent-text-input type="text" id="akaName" name="akaName" maxlength="32" placeholder="custom-alias" pattern="(?!-)([a-z0-9-]+)">Aka Name</fluent-text-input>
                    <div class="form-help">Only lowercase letters, numbers, and hyphens (not at start/end)</div>
                    <div class="invalid-feedback" id="akaNameError"></div>
                </div>
                <div class="form-field">
                    <label for="tags">Tags</label>
                    <input type="text" class="elf-input" id="tags" name="tags" placeholder="Type to search or add tags..." />
                    <div class="form-help">Type to search existing tags or create new ones</div>
                    <div class="invalid-feedback" id="tagsError"></div>
                </div>
            </div>

            <div class="form-grid two-one">
                <div class="form-field">
                    <label for="note">Note</label>
                    <textarea class="elf-textarea" id="note" name="note" rows="2" placeholder="Optional description or note about this link"></textarea>
                    <div class="invalid-feedback" id="noteError"></div>
                </div>
                <div class="form-field switch-field">
                    <fluent-switch id="isEnabled" name="isEnabled" checked>Enable Link</fluent-switch>
                </div>
            </div>

            <div id="modalErrorAlert" class="inline-alert danger d-none" role="alert">
                <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                <span id="modalErrorMessage"></span>
            </div>
        </form>
    </div>
    <div class="dialog-footer">
        <fluent-button appearance="secondary" type="button" data-dialog-close>Cancel</fluent-button>
        <fluent-button appearance="primary" type="button" id="saveLinkBtn">
            <fluent-progress-ring class="inline-progress d-none" id="saveSpinner" aria-hidden="true"></fluent-progress-ring>
            Save
        </fluent-button>
    </div>
</dialog>